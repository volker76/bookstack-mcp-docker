# BookStack connection (required for both modes)
BOOKSTACK_BASE_URL=http://bookstack:80/api
BOOKSTACK_TIMEOUT=30000

# HTTP/OAuth mode
JWT_SECRET=                          # openssl rand -base64 32
BASE_URL=https://mcp.example.com     # public HTTPS URL
MCP_PORT=3100
# SESSION_IDLE_TIMEOUT_MS=1800000
# DEBUG=true
# STDIO_SERVER_PATH=/app/dist/server.js

# Stdio mode only (HTTP mode injects the token via OAuth JWT)
# BOOKSTACK_API_TOKEN=tokenid:tokensecret

# Child process tuning (HTTP mode passes these to the spawned child)
# LOG_LEVEL=error
# NODE_ENV=production
# VERBOSE=1   # Log full request/response JSON on stderr (forces debug level; dev/troubleshooting only)

# MCP initialize instructions (optional)
# If set, this text is returned in result.instructions of the JSON-RPC initialize response.
# Leave empty or unset to omit the field entirely.
# Multi-line text: use \n for newlines, or set the variable via docker-compose environment block.
# See docs/instructions.md for details.
# SERVER_INSTRUCTIONS=This server provides access to BookStack documentation and knowledge base.
